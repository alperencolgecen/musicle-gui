# Auto-detect text files and normalize line endings
* text=auto

# Keep shell scripts LF
*.sh text eol=lf

# Windows scripts use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Mark documentation as text
*.md text
*.txt text

# C/C++ source files
*.c text
*.cpp text
*.h text
*.hpp text

# Python files
*.py text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
